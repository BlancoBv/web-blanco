<script>
    import moment from "moment";
    import createChart from "src/utils/createChart";

    document.addEventListener("astro:page-load", () => {
        if (!(window.location.hash === "#home")) {
            return;
        }

        let data: string | null = localStorage.getItem("data");

        let gastos = 0;
        let ingresos = 0;

        const date = moment();

        if (data !== null) {
            gastos = JSON.parse(data)
                .gasto.filter(
                    (el: [string, number]) =>
                        moment(el[0].split("T")[0]).format("YYYY-MM") ===
                        date.format("YYYY-MM"),
                    "month",
                )
                .reduce((a: number, b: [string, number]) => a + b[1], 0);

            ingresos = JSON.parse(data)
                .ingreso.filter(
                    (el: [string, number]) =>
                        moment(el[0].split("T")[0]).format("YYYY-MM") ===
                        date.format("YYYY-MM"),
                    "month",
                )
                .reduce((a: number, b: [string, number]) => a + b[1], 0);
        }

        const chart = createChart(
            "doughnut",
            "res-circle-mes",
            {
                labels: ["Gastos", "Ingresos"],
                datasets: [
                    {
                        data: [gastos, ingresos],
                        backgroundColor: [
                            "#f87171",
                            "#4ade80",
                            "rgb(255, 205, 86)",
                        ],
                        hoverOffset: 4,
                    },
                ],
            },
            {
                circumference: 180,
                rotation: 270,
            },
        );
    });


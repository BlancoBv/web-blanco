---
import Tabs from "@components/controlGastos/Tabs.astro";
import "../assets/app.css";
import { ClientRouter } from "astro:transitions";
interface Props {
    url: string;
}

const { url } = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="light">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Astro description" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Control de gastos</title>
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
        />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/apple-touch-icon.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="/favicon-32x32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href="/favicon-16x16.png"
        />
        <link rel="manifest" href="/site.webmanifest" />
        <ClientRouter />
    </head>
    <body class="h-dvh group" data-route={url}>
        <div
            class="overflow-y-auto overflow-x-hidden" class:list={{"h-dvh": url==="add", "h-[calc(100dvh-64px)]": !(url==="add")}}
            transition:animate="slide"
        >
        <div class="navbar bg-base-100/70 backdrop-blur-xs shadow-sm h-16 z-50 sticky top-0">
            <div class="flex-1">
                {url==="add" && <a href="javascript:history.back()" class="btn btn-ghost text-xl" data-astro-replace>
                    <i class="bi bi-arrow-left-short text-2xl"></i>
                </a>}
                <button type="button" class="btn btn-ghost text-xl">
                    { url==="add" ? "Añadir registro" : "Control de gastos"}
                </button>
            </div>
            <!--             <div class="flex-none">
                <ul class="menu menu-horizontal px-1">
                    <li>
                        <a href="/control-gastos/lista-mes">Registros del mes</a
                        >
                    </li>
                    <li>
                        <a href="#">Historico</a>
                    </li>
                </ul>
            </div> -->
        </div>
       <div class="p-4"> <slot /> </div>
        </div>
        { !(url==="add") && <div class="fab bottom-20">
            <a
                href="/control-gastos/add"
                class="btn btn-lg btn-circle btn-primary"
                transition:persist
                transition:name="button-add"
            >
                <i class="bi bi-plus text-lg"></i>
            </a>
        </div>
        <Tabs />}
    </body>
</html>
<style is:global>
